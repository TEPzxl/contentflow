# Local shell overrides for Contentflow.
# Copy to .env for personal use; do not commit real secrets.

CONTENTFLOW_CONFIG=configs/config.yaml
CONTENTFLOW_APP_ENV=dev
CONTENTFLOW_APP_MODE=all

CONTENTFLOW_DATABASE_HOST=localhost
CONTENTFLOW_DATABASE_PORT=5432
CONTENTFLOW_DATABASE_USERNAME=contentflow
CONTENTFLOW_DATABASE_PASSWORD=contentflow
CONTENTFLOW_DATABASE_DBNAME=contentflow
CONTENTFLOW_DATABASE_SSLMODE=disable

CONTENTFLOW_REDIS_ADDR=localhost:6379
CONTENTFLOW_REDIS_PASSWORD=
CONTENTFLOW_REDIS_DB=0

CONTENTFLOW_KAFKA_ENABLED=false
CONTENTFLOW_KAFKA_BROKERS=localhost:9092

CONTENTFLOW_AUTH_JWT_SECRET=dev-only-insecure-jwt-secret-change-me
CONTENTFLOW_AUTH_JWT_ISSUER=contentflow

NEXT_PUBLIC_CONTENTFLOW_API_BASE_URL=http://localhost:8080/api/v1
